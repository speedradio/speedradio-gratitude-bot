# Copy to .env.local for local dev — NEVER commit actual values

# Slack App credentials
# Get these from https://api.slack.com/apps → Your App → Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# The Slack channel ID where gratitude posts are broadcast
# Right-click channel in Slack → View channel details → copy the ID at the bottom
GRATITUDE_CHANNEL_ID=C0XXXXXXXXX

# Vercel KV (Redis) — auto-injected in production, needed locally
# Get from Vercel Dashboard → Storage → your KV store → .env.local tab
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# Secret for protecting the monthly cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
